# ============================================================
# 环境变量示例 (复制为 .env.local 并填入真实值; .env.local 已 gitignore)
# 服务端变量不要加 NEXT_PUBLIC_ 前缀, 否则会被打进前端 bundle 泄露。
# ============================================================

# --- Supabase (公共数据发布: 上传 / 实时同步) ---
# 项目 URL, 形如 https://<ref>.supabase.co
SUPABASE_URL=
# service_role / Secret key (绕过 RLS, 仅服务端). 三选一即可, 优先 SUPABASE_SECRET_KEY
SUPABASE_SECRET_KEY=

# --- 管理员上传口令 (上传弹窗校验) ---
ADMIN_UPLOAD_PASSWORD=

# --- DeepSeek API (招聘数据提取等 grunt-work, 由本地脚本/服务端读取) ---
DEEPSEEK_API_KEY=
